{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext"],
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "moduleResolution": "node",
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["./src/*"]
    }
  },
  "include": ["tests/**/*", "gen/**/*"],
  "exclude": ["node_modules/"]
}
